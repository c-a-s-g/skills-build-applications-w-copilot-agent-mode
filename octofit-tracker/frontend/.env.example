# Copy this file to .env.local or .env to configure the frontend environment.
#
# When running inside GitHub Codespaces, set REACT_APP_CODESPACE_NAME to your codespace name
# so the frontend can talk to the backend at https://$REACT_APP_CODESPACE_NAME-8000.app.github.dev
#
# Example:
# REACT_APP_CODESPACE_NAME=my-codespace-name

REACT_APP_CODESPACE_NAME=
